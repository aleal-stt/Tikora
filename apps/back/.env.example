# =============================================================================
# Tikora — Backend (apps/back)
# =============================================================================
# Copiar a .env y completar. Mantener .env fuera del control de versiones.
# Las variables marcadas con (REQUIRED) deben estar definidas para arrancar.
# Las variables sin (REQUIRED) tienen un default razonable en código.

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
# (REQUIRED) Puerto HTTP donde escucha el backend
PORT=3001

# (REQUIRED) Modo de ejecución: development | staging | production
NODE_ENV=development

# Nivel de logs: debug | info | warn | error
LOG_LEVEL=info

# CORS: lista de orígenes permitidos separada por coma.
# En dev y prod se espera same-origin (proxy de Vite o reverse proxy);
# acá solo se listan orígenes alternativos si fuera necesario.
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# MongoDB (Atlas o local)
# -----------------------------------------------------------------------------
# (REQUIRED) Cadena de conexión completa
MONGODB_URI=mongodb://localhost:27017/tikora

# Nombre del índice Atlas Vector Search ya creado sobre kb_chunks
# (ver tikora-setup.md §4 — se crea manualmente desde Atlas UI)
MONGODB_VECTOR_INDEX_NAME=kb_chunks_vector

# -----------------------------------------------------------------------------
# Redis (BullMQ + SSE tickets)
# -----------------------------------------------------------------------------
# (REQUIRED) URL de conexión a Redis
REDIS_URL=redis://localhost:6379

# Prefijo para namespaces (colas y claves SSE)
REDIS_KEY_PREFIX=tikora

# -----------------------------------------------------------------------------
# Tenant
# -----------------------------------------------------------------------------
# (REQUIRED MVP) ID del tenant único del MVP. Se crea por seed al arrancar.
DEFAULT_TENANT_ID=tenant-default
DEFAULT_TENANT_NAME=Empresa Demo
DEFAULT_TENANT_TIMEZONE=America/Argentina/Buenos_Aires

# Admin inicial creado por seed (solo si la base está vacía)
SEED_ADMIN_EMAIL=admin@empresa.com
SEED_ADMIN_FULLNAME=Administrador
# Contraseña inicial — el admin la cambia en el primer login
SEED_ADMIN_PASSWORD=ChangeMe123!

# -----------------------------------------------------------------------------
# Autenticación
# -----------------------------------------------------------------------------
# (REQUIRED) Secretos JWT — generar con: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_SSE_SECRET=

# Vencimientos
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SSE_TICKET_EXPIRES_IN=90s

# Cookies
# COOKIE_SECURE=true solo cuando se sirve por HTTPS (prod). En dev local: false.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Política de bloqueo por intentos fallidos
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# -----------------------------------------------------------------------------
# IA — LLM vía API OpenAI-compatible (default: Gemini)
# -----------------------------------------------------------------------------
# (REQUIRED) API key del proveedor. Por default Gemini — generar gratis en
# https://aistudio.google.com/apikey. Cualquier proveedor OpenAI-compatible
# (OpenRouter, OpenAI directo, vLLM self-hosted, etc.) encaja cambiando la
# combinación de LLM_API_KEY + LLM_BASE_URL + LLM_MODEL_*.
LLM_API_KEY=

# Endpoint base. El default es el endpoint OpenAI-compat de Gemini.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Modelos por uso. `flash-lite` para clasificación (rápido, JSON corto)
# y `flash` para auto-respuesta (mejor redacción larga). Ambos son free.
LLM_MODEL_CLASSIFICATION=gemini-2.0-flash-lite
LLM_MODEL_RESPONSE=gemini-2.0-flash

# Comportamiento del cliente
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_MS=1000
# Prompt caching está documentado en tikora-ia.md como feature de Anthropic.
# Los modelos free de OpenRouter no lo soportan — dejamos el flag para
# cuando se integre un proveedor compatible.
LLM_PROMPT_CACHE_ENABLED=false

# Generación
LLM_MAX_TOKENS_CLASSIFICATION=1024
LLM_MAX_TOKENS_RESPONSE=2048
LLM_TEMP_CLASSIFICATION=0.0
LLM_TEMP_RESPONSE=0.3

# Versiones de prompt activas
CLASSIFICATION_PROMPT_VERSION=v1
RESPONSE_PROMPT_VERSION=v1

# Umbrales (espejo en settings del tenant; estos son fallback)
UMBRAL_CONFIANZA_CLASIFICACION=0.7
UMBRAL_RELEVANCIA_KB=0.75
UMBRAL_AUTO_AUTONOMA=0.9
AUTO_AUTONOMA_SAMPLE_RATE=0.1

# Truncado del cuerpo del ticket antes de enviar al modelo
MAX_TICKET_BODY_TOKENS=4000

# Presupuesto mensual (alarma cuando se cruza)
ANTHROPIC_MONTHLY_BUDGET_USD=50

# -----------------------------------------------------------------------------
# Embeddings (Transformers.js local)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=Xenova/multilingual-e5-small
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=8

# Directorio de cache local del modelo
TRANSFORMERS_CACHE=./.cache/transformers

# -----------------------------------------------------------------------------
# Email — SMTP genérico (recomendado: Gmail con app password, gratis)
# -----------------------------------------------------------------------------
# Setup detallado en tikora-setup.md §4.4. En resumen para Gmail:
#   1. Activar 2FA en https://myaccount.google.com/security
#   2. Generar app password en https://myaccount.google.com/apppasswords
#   3. Pegar el app password de 16 chars en SMTP_PASS (la contraseña
#      normal de Gmail NO funciona con SMTP).
#   4. EMAIL_FROM y SMTP_USER deben coincidir (Gmail bloquea spoofing).
#
# `log` imprime a stdout sin enviar. Cambiar a `live` cuando SMTP_PASS
# esté seteado — si está vacío en modo live, el back falla al boot.
EMAIL_DELIVERY_MODE=log

EMAIL_FROM=Tikora <noreply@empresa.com>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# false = STARTTLS sobre 587 (Gmail). true = TLS directo (típico 465).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Adjuntos
# -----------------------------------------------------------------------------
UPLOADS_DIR=./uploads
MAX_ATTACHMENT_SIZE_MB=10
MAX_ATTACHMENTS_PER_TICKET=5

# -----------------------------------------------------------------------------
# SLA
# -----------------------------------------------------------------------------
SLA_BUSINESS_HOURS_START=07:00
SLA_BUSINESS_HOURS_END=18:00
SLA_REOPEN_GRACE_DAYS=5
SLA_AUTO_CLOSE_DAYS=15
SLA_TICK_INTERVAL_SECONDS=60

# -----------------------------------------------------------------------------
# Rate limiting (NestJS Throttler)
# -----------------------------------------------------------------------------
THROTTLE_AUTH_TTL_SECONDS=60
THROTTLE_AUTH_LIMIT=10
THROTTLE_DEFAULT_TTL_SECONDS=60
THROTTLE_DEFAULT_LIMIT=120

# -----------------------------------------------------------------------------
# Observabilidad
# -----------------------------------------------------------------------------
# DSN de Sentry (vacío en dev = Sentry apagado)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Habilitar Swagger en /api/docs (típicamente apagado en prod)
SWAGGER_ENABLED=true

# -----------------------------------------------------------------------------
# Featureflags / fases
# -----------------------------------------------------------------------------
# Fase activa de la IA: 1 (clasificación), 2 (auto-respuesta con humano), 3 (autónomo)
AI_PHASE=1
