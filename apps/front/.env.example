# =============================================================================
# Tikora — Frontend (apps/front)
# =============================================================================
# Vite expone al cliente solo las variables que empiezan con VITE_.
# Copiar a .env y completar. Mantener .env fuera del control de versiones.

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# URL base de la API. En dev se usa la ruta relativa para que el proxy de Vite
# (vite.config.ts) reenvíe a localhost:3001 → cookies same-origin.
# En prod queda igual (relativa) si front y back comparten reverse proxy.
VITE_API_URL=/api/v1

# Nombre del producto visible
VITE_APP_NAME=Tikora

# Ambiente: development | staging | production
VITE_ENV=development

# -----------------------------------------------------------------------------
# Adjuntos (espejo del backend para validación cliente antes de subir)
# -----------------------------------------------------------------------------
VITE_MAX_ATTACHMENT_SIZE_MB=10
VITE_MAX_ATTACHMENTS_PER_TICKET=5

# -----------------------------------------------------------------------------
# Listados
# -----------------------------------------------------------------------------
VITE_PAGE_SIZE=50

# -----------------------------------------------------------------------------
# Sentry — observabilidad cliente
# -----------------------------------------------------------------------------
# DSN del proyecto en Sentry. Vacío = Sentry apagado (típico en dev).
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
